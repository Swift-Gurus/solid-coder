{
  "name": "solid-coder",
  "version": "1.4.0",
  "description": "Plugin with skills/workflows using solid principles",
  "author": {
    "name": "Alex Crowe"
  },
  "mcpServers": {
    "apple-build": {
      "command": "python3",
      "args": ["${CLAUDE_PLUGIN_ROOT}/mcp-server/build/apple/server.py"]
    },
    "docs": {
      "command": "python3",
      "args": ["${CLAUDE_PLUGIN_ROOT}/mcp-server/docs/server.py"]
    },
    "specs": {
      "command": "python3",
      "args": ["${CLAUDE_PLUGIN_ROOT}/mcp-server/specs/server.py"]
    },
    "pipeline": {
      "command": "python3",
      "args": ["${CLAUDE_PLUGIN_ROOT}/mcp-server/pipeline/server.py"]
    }
  }
}
