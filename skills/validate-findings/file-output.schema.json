{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Validated File Output",
  "description": "Filtered findings and suggestions for a single file, grouped by principle.",
  "type": "object",
  "required": ["file", "timestamp", "principles"],
  "properties": {
    "file": {
      "type": "string",
      "description": "Full path to the source file"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "principles": {
      "type": "array",
      "description": "One entry per principle that has findings for this file",
      "items": {
        "type": "object",
        "required": ["agent", "principle", "severity", "findings", "suggestions"],
        "properties": {
          "agent": {
            "type": "string",
            "description": "Principle agent id (srp, ocp, lsp, isp)"
          },
          "principle": {
            "type": "string",
            "description": "Full principle name"
          },
          "unit_name": {
            "type": "string",
            "description": "Name of the unit (class, struct, protocol, etc.) this entry covers"
          },
          "unit_kind": {
            "type": "string",
            "description": "Kind of the unit (class, struct, enum, protocol, extension)"
          },
          "severity": {
            "type": "string",
            "enum": ["COMPLIANT", "MINOR", "SEVERE"],
            "description": "Worst severity among remaining findings for this principle on this file"
          },
          "findings": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "severity", "metric", "title", "issue"],
              "properties": {
                "id": { "type": "string" },
                "severity": { "type": "string" },
                "metric": { "type": "string" },
                "line_start": { "type": "integer" },
                "line_end": { "type": "integer" },
                "title": { "type": "string" },
                "issue": { "type": "string" },
                "impact": { "type": "string" },
                "rule_source": { "type": "string" }
              }
            }
          },
          "suggestions": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "addresses", "title", "severity", "suggested_fix", "todo_items"],
              "properties": {
                "id": { "type": "string" },
                "addresses": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "title": { "type": "string" },
                "severity": { "type": "string" },
                "pattern": { "type": "string" },
                "suggested_fix": { "type": "string" },
                "todo_items": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "verification": { "type": "object" }
              }
            }
          }
        }
      }
    }
  }
}
