{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Architecture Decomposition",
  "description": "High-level architecture decomposition produced by /plan. Describes components, their interfaces, dependencies, wiring, and data models.",
  "type": "object",
  "required": ["spec_summary", "components", "wiring", "composition_root", "data_models"],
  "properties": {
    "spec_summary": {
      "type": "string",
      "description": "One-line summary of what's being built"
    },
    "components": {
      "type": "array",
      "description": "Decomposed components with responsibilities, interfaces, and dependencies",
      "items": {
        "type": "object",
        "required": ["name", "category", "stack", "responsibility", "interfaces", "dependencies", "produces"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Type name following create-type naming conventions"
          },
          "category": {
            "type": "string",
            "description": "solid-category vocabulary value (e.g., network, viewmodel, repository)"
          },
          "stack": {
            "type": "array",
            "items": { "type": "string" },
            "description": "solid-stack vocabulary values (e.g., swiftui, structured-concurrency). Empty array if pure language code."
          },
          "responsibility": {
            "type": "string",
            "description": "One sentence describing what this component does"
          },
          "interfaces": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Protocols this component exposes"
          },
          "dependencies": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Protocols this component consumes (injected)"
          },
          "produces": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Data types this component outputs"
          }
        }
      }
    },
    "wiring": {
      "type": "array",
      "description": "Dependency injection wiring between components",
      "items": {
        "type": "object",
        "required": ["from", "to", "via"],
        "properties": {
          "from": {
            "type": "string",
            "description": "Consumer component name"
          },
          "to": {
            "type": "string",
            "description": "Protocol being consumed"
          },
          "via": {
            "type": "string",
            "enum": ["init", "environment", "closure"],
            "description": "Injection method"
          }
        }
      }
    },
    "composition_root": {
      "type": "string",
      "description": "Name of the factory or assembly point where concrete types are wired together"
    },
    "data_models": {
      "type": "array",
      "description": "Data types used across components",
      "items": {
        "type": "object",
        "required": ["name", "category", "fields"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Model type name"
          },
          "category": {
            "type": "string",
            "description": "Always 'model'"
          },
          "fields": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Field declarations (e.g., 'id: String', 'name: String')"
          }
        }
      }
    }
  }
}