{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SwiftUI Review Output",
  "type": "object",
  "required": ["agent", "principle", "timestamp", "files"],
  "properties": {
    "agent": { "const": "swiftui" },
    "principle": { "const": "SwiftUI Best Practices" },
    "timestamp": { "type": "string", "format": "date-time" },
    "documentation_sources": {
      "type": "array",
      "items": { "type": "string" }
    },
    "files": {
      "type": "array",
      "description": "Per-file analysis results",
      "items": {
        "type": "object",
        "required": ["file", "units"],
        "properties": {
          "file": {
            "type": "string",
            "description": "Full path to the reviewed file"
          },
          "units": {
            "type": "array",
            "description": "Per-unit analysis results within this file",
            "items": {
              "type": "object",
              "required": ["unit_name", "unit_kind", "metrics", "scoring", "findings"],
              "properties": {
                "unit_name": {
                  "type": "string",
                  "description": "Name of the analyzed view (e.g., struct name)"
                },
                "unit_kind": {
                  "type": "string",
                  "enum": ["class", "struct", "enum", "protocol", "extension"],
                  "description": "Kind of the analyzed unit"
                },
                "metrics": {
                  "type": "object",
                  "required": ["body_complexity", "view_purity", "modifier_chain", "vm_injection", "preview_containment"],
                  "properties": {
                    "body_complexity": {
                      "type": "object",
                      "required": ["max_nesting_depth", "view_expression_count"],
                      "properties": {
                        "max_nesting_depth": { "type": "integer" },
                        "view_expression_count": { "type": "integer" }
                      }
                    },
                    "view_purity": {
                      "type": "object",
                      "required": ["impure_count", "has_data_fetch", "table"],
                      "properties": {
                        "impure_count": { "type": "integer" },
                        "has_data_fetch": { "type": "boolean" },
                        "table": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "required": ["method", "classification", "reason"],
                            "properties": {
                              "method": { "type": "string" },
                              "classification": {
                                "type": "string",
                                "enum": ["PURE_VIEW", "DATA_FETCH", "TRANSFORM", "FORMAT", "VALIDATE", "COMPUTE"]
                              },
                              "reason": { "type": "string" }
                            }
                          }
                        }
                      }
                    },
                    "modifier_chain": {
                      "type": "object",
                      "required": ["max_nested_chain", "flagged_views"],
                      "properties": {
                        "max_nested_chain": {
                          "type": "integer",
                          "description": "Highest modifier count on any nested child view"
                        },
                        "flagged_views": {
                          "type": "array",
                          "description": "Nested child views with modifier count > 2",
                          "items": {
                            "type": "object",
                            "required": ["view_expression", "location", "modifier_count"],
                            "properties": {
                              "view_expression": { "type": "string" },
                              "location": { "type": "string", "description": "Which property/closure this appears in" },
                              "modifier_count": { "type": "integer" }
                            }
                          }
                        }
                      }
                    }
                  },
                  "vm_injection": {
                    "type": "object",
                    "required": ["has_vm", "injection_style"],
                    "properties": {
                      "has_vm": {
                        "type": "boolean",
                        "description": "Whether the view has a ViewModel dependency for logic/data access"
                      },
                      "injection_style": {
                        "type": "string",
                        "enum": ["protocol", "concrete", "n/a"],
                        "description": "How the VM is injected: protocol (generic constraint), concrete (class type), or n/a (no VM)"
                      },
                      "vm_property": {
                        "type": "string",
                        "description": "Name of the VM property (if applicable)"
                      },
                      "vm_type": {
                        "type": "string",
                        "description": "Type of the VM property (if applicable)"
                      }
                    }
                  },
                  "preview_containment": {
                    "type": "object",
                    "required": ["preview_only_types"],
                    "properties": {
                      "preview_only_types": {
                        "type": "array",
                        "description": "File-scope types only referenced from #Preview/PreviewProvider. Empty array if all types have production callers.",
                        "items": {
                          "type": "object",
                          "required": ["name", "kind", "classification"],
                          "properties": {
                            "name": { "type": "string", "description": "Type name" },
                            "kind": { "type": "string", "enum": ["view", "helper"], "description": "Whether it's a View struct or a supporting helper type" },
                            "classification": { "type": "string", "enum": ["PREVIEW_ONLY", "PRODUCTION"], "description": "PREVIEW_ONLY if only referenced from preview blocks" }
                          }
                        }
                      }
                    }
                  }
                },
                "scoring": {
                  "type": "object",
                  "required": ["body_severity", "purity_severity", "modifier_chain_severity", "vm_injection_severity", "preview_containment_severity", "final_severity"],
                  "properties": {
                    "body_severity": { "type": "string" },
                    "purity_severity": { "type": "string" },
                    "modifier_chain_severity": { "type": "string" },
                    "vm_injection_severity": { "type": "string" },
                    "preview_containment_severity": { "type": "string" },
                    "final_severity": {
                      "type": "string",
                      "enum": ["COMPLIANT", "SEVERE"]
                    }
                  }
                },
                "findings": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["id", "severity", "metric", "title", "issue"],
                    "properties": {
                      "id": {
                        "type": "string",
                        "pattern": "^sui-\\d{3}$"
                      },
                      "severity": {
                        "type": "string",
                        "enum": ["SEVERE"]
                      },
                      "metric": {
                        "type": "string",
                        "enum": ["SUI-1", "SUI-2", "SUI-3", "SUI-4", "SUI-5"],
                        "description": "Which metric triggered this finding"
                      },
                      "line_start": { "type": "integer" },
                      "line_end": { "type": "integer" },
                      "title": { "type": "string" },
                      "issue": { "type": "string" },
                      "impact": { "type": "string" },
                      "rule_source": { "type": "string" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
