{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SwiftUI Fix Output",
  "type": "object",
  "required": ["agent", "principle", "timestamp", "files"],
  "properties": {
    "agent": { "const": "swiftui" },
    "principle": { "const": "SwiftUI Best Practices" },
    "timestamp": { "type": "string", "format": "date-time" },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["file_path", "suggestions"],
        "properties": {
          "file_path": {
            "type": "string",
            "description": "Full path to the reviewed file"
          },
          "suggestions": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["suggestion_id", "addresses", "suggested_fix", "todo_items", "verification"],
              "properties": {
                "suggestion_id": {
                  "type": "string",
                  "pattern": "^sui-fix-\\d{3}$"
                },
                "addresses": {
                  "type": "array",
                  "items": { "type": "string" },
                  "description": "Finding IDs this suggestion resolves (e.g., sui-001)"
                },
                "suggested_fix": {
                  "type": "string",
                  "description": "Full text description with code snippets showing the refactored code"
                },
                "todo_items": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["step", "action"],
                    "properties": {
                      "step": { "type": "integer" },
                      "action": { "type": "string" }
                    }
                  }
                },
                "verification": {
                  "type": "object",
                  "description": "Predicted post-fix metrics for each resulting view/type",
                  "required": ["predicted_metrics"],
                  "properties": {
                    "predicted_metrics": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "required": ["unit_name", "nesting_depth", "view_expressions", "impure_count", "max_nested_modifier_chain", "vm_injection_style"],
                        "properties": {
                          "unit_name": { "type": "string" },
                          "nesting_depth": { "type": "integer" },
                          "view_expressions": { "type": "integer" },
                          "impure_count": { "type": "integer" },
                          "max_nested_modifier_chain": { "type": "integer", "description": "Highest modifier count on any nested child view after fix" },
                          "vm_injection_style": { "type": "string", "enum": ["protocol", "concrete", "n/a"], "description": "VM injection style after fix: protocol (generic constraint), concrete (class type), or n/a (no VM)" },
                          "has_preview": { "type": "boolean", "description": "Whether the view has preview coverage after fix" }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
