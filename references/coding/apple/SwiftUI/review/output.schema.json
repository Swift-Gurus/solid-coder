{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SwiftUI Review Output",
  "type": "object",
  "required": ["agent", "principle", "timestamp", "files"],
  "properties": {
    "agent": { "const": "swiftui" },
    "principle": { "const": "SwiftUI Best Practices" },
    "timestamp": { "type": "string", "format": "date-time" },
    "documentation_sources": {
      "type": "array",
      "items": { "type": "string" }
    },
    "files": {
      "type": "array",
      "description": "Per-file analysis results",
      "items": {
        "type": "object",
        "required": ["file_path", "units"],
        "properties": {
          "file_path": {
            "type": "string",
            "description": "Full path to the reviewed file"
          },
          "units": {
            "type": "array",
            "description": "Per-unit analysis results within this file",
            "items": {
              "type": "object",
              "required": ["unit_name", "unit_kind", "metrics", "scoring", "findings"],
              "properties": {
                "unit_name": {
                  "type": "string",
                  "description": "Name of the analyzed view (e.g., struct name)"
                },
                "unit_kind": {
                  "type": "string",
                  "enum": ["class", "struct", "enum", "protocol", "extension"],
                  "description": "Kind of the analyzed unit"
                },
                "metrics": {
                  "type": "object",
                  "required": ["body_complexity", "view_purity", "modifier_chain", "vm_injection", "preview_containment", "preview_coverage", "container_accessibility", "adaptive_sizing", "actor_isolation"],
                  "properties": {
                    "body_complexity": {
                      "type": "object",
                      "required": ["max_nesting_depth", "view_expression_count"],
                      "properties": {
                        "max_nesting_depth": { "type": "integer" },
                        "view_expression_count": { "type": "integer" }
                      }
                    },
                    "view_purity": {
                      "type": "object",
                      "required": ["impure_count", "has_data_fetch", "table"],
                      "properties": {
                        "impure_count": { "type": "integer" },
                        "has_data_fetch": { "type": "boolean" },
                        "table": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "required": ["method", "classification", "reason"],
                            "properties": {
                              "method": { "type": "string" },
                              "classification": {
                                "type": "string",
                                "enum": ["PURE_VIEW", "DATA_FETCH", "TRANSFORM", "FORMAT", "VALIDATE", "COMPUTE"]
                              },
                              "reason": { "type": "string" }
                            }
                          }
                        }
                      }
                    },
                    "modifier_chain": {
                      "type": "object",
                      "required": ["max_nested_chain", "flagged_views"],
                      "properties": {
                        "max_nested_chain": {
                          "type": "integer",
                          "description": "Highest modifier count on any nested child view"
                        },
                        "flagged_views": {
                          "type": "array",
                          "description": "Nested child views with modifier count > 2",
                          "items": {
                            "type": "object",
                            "required": ["view_expression", "location", "modifier_count"],
                            "properties": {
                              "view_expression": { "type": "string" },
                              "location": { "type": "string", "description": "Which property/closure this appears in" },
                              "modifier_count": { "type": "integer" }
                            }
                          }
                        }
                      }
                    }
                  },
                  "vm_injection": {
                    "type": "object",
                    "required": ["has_vm", "injection_style"],
                    "properties": {
                      "has_vm": {
                        "type": "boolean",
                        "description": "Whether the view has a ViewModel dependency for logic/data access"
                      },
                      "injection_style": {
                        "type": "string",
                        "enum": ["protocol", "concrete", "n/a"],
                        "description": "How the VM is injected: protocol (generic constraint), concrete (class type), or n/a (no VM)"
                      },
                      "vm_property": {
                        "type": "string",
                        "description": "Name of the VM property (if applicable)"
                      },
                      "vm_type": {
                        "type": "string",
                        "description": "Type of the VM property (if applicable)"
                      }
                    }
                  },
                  "preview_containment": {
                    "type": "object",
                    "required": ["preview_only_types"],
                    "properties": {
                      "preview_only_types": {
                        "type": "array",
                        "description": "File-scope types only referenced from #Preview/PreviewProvider. Empty array if all types have production callers.",
                        "items": {
                          "type": "object",
                          "required": ["name", "kind", "classification"],
                          "properties": {
                            "name": { "type": "string", "description": "Type name" },
                            "kind": { "type": "string", "enum": ["view", "helper"], "description": "Whether it's a View struct or a supporting helper type" },
                            "classification": { "type": "string", "enum": ["PREVIEW_ONLY", "PRODUCTION"], "description": "PREVIEW_ONLY if only referenced from preview blocks" }
                          }
                        }
                      }
                    }
                  },
                  "preview_coverage": {
                    "type": "object",
                    "required": ["views_without_preview"],
                    "properties": {
                      "views_without_preview": {
                        "type": "array",
                        "description": "File-scope View structs with no #Preview or PreviewProvider instantiation anywhere. Empty array if all views have preview coverage.",
                        "items": {
                          "type": "object",
                          "required": ["name", "file"],
                          "properties": {
                            "name": { "type": "string", "description": "View struct name" },
                            "file": { "type": "string", "description": "File where the view is declared" }
                          }
                        }
                      }
                    }
                  },
                  "container_accessibility": {
                    "type": "object",
                    "required": ["flagged_containers"],
                    "properties": {
                      "flagged_containers": {
                        "type": "array",
                        "description": "Container views with .accessibilityIdentifier but missing .accessibilityElement(children:). Empty array if all containers are compliant.",
                        "items": {
                          "type": "object",
                          "required": ["container_type", "location", "has_accessibility_element", "has_accessibility_identifier"],
                          "properties": {
                            "container_type": { "type": "string", "description": "Container view type (e.g., HStack, VStack, List)" },
                            "location": { "type": "string", "description": "Line number or property where the container appears" },
                            "has_accessibility_element": { "type": "boolean" },
                            "has_accessibility_identifier": { "type": "boolean" }
                          }
                        }
                      }
                    }
                  },
                  "adaptive_sizing": {
                    "type": "object",
                    "required": ["fixed_frame_count", "flagged_frames"],
                    "properties": {
                      "fixed_frame_count": {
                        "type": "integer",
                        "description": "Number of .frame() calls with literal numeric width/height values"
                      },
                      "flagged_frames": {
                        "type": "array",
                        "description": ".frame() calls with hardcoded literal numeric width or height. Empty array if no fixed frames.",
                        "items": {
                          "type": "object",
                          "required": ["view_expression", "location", "fixed_dimension"],
                          "properties": {
                            "view_expression": { "type": "string", "description": "The view expression with the fixed frame" },
                            "location": { "type": "string", "description": "Line number or property where the frame appears" },
                            "fixed_dimension": { "type": "string", "description": "Which dimension is hardcoded (width, height, or both)" }
                          }
                        }
                      }
                    }
                  },
                  "actor_isolation": {
                    "type": "object",
                    "required": ["over_isolated_count", "nonisolated_escape_count", "flagged_types"],
                    "properties": {
                      "over_isolated_count": {
                        "type": "integer",
                        "description": "Number of types/protocols with @MainActor that have background-safe members"
                      },
                      "nonisolated_escape_count": {
                        "type": "integer",
                        "description": "Total nonisolated members across @MainActor types (code smell indicator)"
                      },
                      "flagged_types": {
                        "type": "array",
                        "description": "Types/protocols with over-broad @MainActor. Empty array if all actor annotations are granular.",
                        "items": {
                          "type": "object",
                          "required": ["type_name", "type_kind", "total_members", "background_safe_members", "nonisolated_members", "violation_kind"],
                          "properties": {
                            "type_name": { "type": "string", "description": "Name of the over-isolated type" },
                            "type_kind": { "type": "string", "enum": ["class", "struct", "protocol", "extension"], "description": "Kind of type declaration" },
                            "total_members": { "type": "integer", "description": "Total methods and properties" },
                            "background_safe_members": {
                              "type": "array",
                              "items": { "type": "string" },
                              "description": "Names of members that don't need main thread"
                            },
                            "nonisolated_members": {
                              "type": "array",
                              "items": { "type": "string" },
                              "description": "Names of members marked nonisolated (escape hatch smell)"
                            },
                            "violation_kind": {
                              "type": "string",
                              "enum": ["type_over_isolation", "protocol_over_isolation", "nonisolated_escape"],
                              "description": "Which SUI-9 violation pattern this matches"
                            },
                            "conformer_analysis": {
                              "type": "object",
                              "description": "For protocols only — analysis of production conformers",
                              "properties": {
                                "production_conformers": {
                                  "type": "array",
                                  "items": { "type": "string" },
                                  "description": "Names of production conformers (excluding preview/test doubles)"
                                },
                                "all_conformers_main_actor": {
                                  "type": "boolean",
                                  "description": "True if all production conformers are @MainActor — protocol-level @MainActor is COMPLIANT"
                                },
                                "conformer_needing_background": {
                                  "type": "string",
                                  "description": "Name of the conformer that needs background work (if any — triggers SEVERE)"
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                },
                "scoring": {
                  "type": "object",
                  "required": ["body_severity", "purity_severity", "modifier_chain_severity", "vm_injection_severity", "preview_containment_severity", "preview_coverage_severity", "container_accessibility_severity", "adaptive_sizing_severity", "actor_isolation_severity", "final_severity"],
                  "properties": {
                    "body_severity": { "type": "string" },
                    "purity_severity": { "type": "string" },
                    "modifier_chain_severity": { "type": "string" },
                    "vm_injection_severity": { "type": "string" },
                    "preview_containment_severity": { "type": "string" },
                    "preview_coverage_severity": { "type": "string" },
                    "container_accessibility_severity": { "type": "string" },
                    "adaptive_sizing_severity": { "type": "string" },
                    "actor_isolation_severity": { "type": "string" },
                    "final_severity": {
                      "type": "string",
                      "enum": ["COMPLIANT", "SEVERE"]
                    }
                  }
                },
                "findings": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["id", "severity", "metric", "title", "issue"],
                    "properties": {
                      "id": {
                        "type": "string",
                        "pattern": "^sui-\\d{3}$"
                      },
                      "severity": {
                        "type": "string",
                        "enum": ["SEVERE"]
                      },
                      "metric": {
                        "type": "string",
                        "enum": ["SUI-1", "SUI-2", "SUI-3", "SUI-4", "SUI-5", "SUI-6", "SUI-7", "SUI-8", "SUI-9"],
                        "description": "Which metric triggered this finding"
                      },
                      "line_start": { "type": "integer" },
                      "line_end": { "type": "integer" },
                      "title": { "type": "string" },
                      "issue": { "type": "string" },
                      "impact": { "type": "string" },
                      "rule_source": { "type": "string" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
