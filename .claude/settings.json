{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | grep -q '/references/' && python3 \"$CLAUDE_PROJECT_DIR/scripts/regen-token-docs.py\" || true"
          }
        ]
      }
    ]
  }
}
